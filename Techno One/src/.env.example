# ── Required ──────────────────────────────────────────────
BITRIX_WEBHOOK_URL=https://your.bitrix24.com/rest/1/xxxxxx/
SALES_WHATSAPP_NUMBER=923011233333

# ── Meta Conversions API (optional, for Facebook tracking) ─
META_PIXEL_ID=1234567890
META_CAPI_ACCESS_TOKEN=EAxxxxxx
# META_TEST_EVENT_CODE=TESTxxxx        # remove in production

# ── WAHA WhatsApp API (optional, for internal notifications) ─
# WAHA_BASE_URL=https://your-waha-instance.example.com
# WAHA_SESSION=default
# WAHA_API_KEY=your-api-key

# ── Bitrix24 Custom UF Fields (optional) ─────────────────
# Create fields in Bitrix24 CRM first, then map them here.
# BITRIX_UF_MAPPING={"UF_CRM_BUDGET":"budget","UF_CRM_INTEREST":"interest","UF_CRM_PREFERENCES":"want"}

# ── GA4 (optional) ───────────────────────────────────────
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
