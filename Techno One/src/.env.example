# Copy this file to .env (local dev) or set these in your hosting dashboard
# (Vercel: Project Settings -> Environment Variables). Never commit real
# values to git.

# --- Meta Pixel / Conversions API ---
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# --- Bitrix24 ---
# Inbound webhook URL with crm.lead.add rights, e.g.
# https://yourcompany.bitrix24.com/rest/1/xxxxxxxxxxxxxxxx
BITRIX_WEBHOOK_URL=

# --- WAHA (WhatsApp HTTP API) ---
WAHA_BASE_URL=
WAHA_SESSION=default
WAHA_API_KEY=
SALES_WHATSAPP_NUMBER=923011233333

# --- Analytics ---
GA4_MEASUREMENT_ID=
